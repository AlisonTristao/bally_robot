(pcb freerouting.dsn
  (parser
    (string_quote ")
    (space_in_quoted_tokens on)
    (host_cad "KiCad's Pcbnew")
    (host_version "9.0.3")
  )
  (resolution um 10)
  (unit um)
  (structure
    (layer F.Cu
      (type signal)
      (property
        (index 0)
      )
    )
    (layer B.Cu
      (type signal)
      (property
        (index 1)
      )
    )
    (boundary
      (path pcb 0  200025 -117025  105975 -117025  105975 -31475  200025 -31475
            200025 -117025)
    )
    (via "Via[0-1]_600:300_um")
    (rule
      (width 200)
      (clearance 200)
      (clearance 50 (type smd_smd))
    )
  )
  (placement
  )
  (library
    (padstack "Via[0-1]_600:300_um"
      (shape (circle F.Cu 600))
      (shape (circle B.Cu 600))
      (attach off)
    )
  )
  (network
    (class kicad_default +12V +3.3V +3V3 +5V BOOT BTN_1 BTN_2 BZR CD CS D+
      "D-" DIV_TENSAO ENC1_D ENC1_E ENC2_D ENC2_E GND IN1_D IN1_E IN2_D IN2_E
