      "Net-(D1-A)" "Net-(D2-K)" "Net-(D3-K)" "Net-(D4-K)" "Net-(D5-K)" "Net-(D6-K)"
      "Net-(J2-Pin_1)" "Net-(J2-Pin_2)" "Net-(J2-Pin_3)" "Net-(J2-Pin_4)"
      "Net-(J2-Pin_5)" "Net-(J2-Pin_6)" "Net-(J2-Pin_7)" "Net-(J2-Pin_8)"
      "Net-(P1-GND-PadG2)" "Net-(Q1-B)" "Net-(Q2-B)" "Net-(U10-BST)" "Net-(U10-SW)"
      "Net-(U2-A)" "Net-(U3-A)" "Net-(U7-A)" "Net-(U8-A)" "Net-(U9A--)" "Net-(U9B--)"
      OUT1_D OUT1_E OUT2_D OUT2_E RST RX S0 S1 S2 SCK SCL SDA SD_anal SD_digital
      SE_anal SE_digital SIG TX Vin i_D i_E strp_1 strp_2 "unconnected-(P1-DAT1-Pad8)"
      "unconnected-(P1-DAT2-Pad1)" "unconnected-(U1-GPIO10{slash}TOUCH10{slash}ADC1_CH9{slash}FSPICS0{slash}FSPIIO4{slash}SUBSPICS0-Pad18)"
      "unconnected-(U1-GPIO11{slash}TOUCH11{slash}ADC2_CH0{slash}FSPID{slash}FSPIIO5{slash}SUBSPID-Pad19)"
      "unconnected-(U1-GPIO14{slash}TOUCH14{slash}ADC2_CH3{slash}FSPIWP{slash}FSPIDQS{slash}SUBSPIWP-Pad22)"
      "unconnected-(U1-GPIO15{slash}U0RTS{slash}ADC2_CH4{slash}XTAL_32K_P-Pad8)"
      "unconnected-(U1-GPIO16{slash}U0CTS{slash}ADC2_CH5{slash}XTAL_32K_N-Pad9)"
      "unconnected-(U1-GPIO17{slash}U1TXD{slash}ADC2_CH6-Pad10)" "unconnected-(U1-GPIO18{slash}U1RXD{slash}ADC2_CH7{slash}CLK_OUT3-Pad11)"
      "unconnected-(U1-GPIO19{slash}U1RTS{slash}ADC2_CH8{slash}CLK_OUT2{slash}USB_D--Pad13)"
      "unconnected-(U1-GPIO1{slash}TOUCH1{slash}ADC1_CH0-Pad39)" "unconnected-(U1-GPIO20{slash}U1CTS{slash}ADC2_CH9{slash}CLK_OUT1{slash}USB_D+-Pad14)"
      "unconnected-(U1-GPIO21-Pad23)" "unconnected-(U1-GPIO2{slash}TOUCH2{slash}ADC1_CH1-Pad38)"
      "unconnected-(U1-GPIO38{slash}FSPIWP{slash}SUBSPIWP-Pad31)" "unconnected-(U1-GPIO3{slash}TOUCH3{slash}ADC1_CH2-Pad15)"
      "unconnected-(U1-GPIO47{slash}SPICLK_P{slash}SUBSPICLK_P_DIFF-Pad24)"
      "unconnected-(U1-GPIO48{slash}SPICLK_N{slash}SUBSPICLK_N_DIFF-Pad25)"
